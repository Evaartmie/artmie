    "@remix-run/serve": "^2.7.1",
    "@shopify/polaris": "^13.0.0",
    "@shopify/shopify-app-remix": "^3.0.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.0.0",
    "date-fns": "^3.6.0",
    "isbot": "^5.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^3.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@remix-run/eslint-config": "^2.7.1",
