{
  "name": "shopify-returns-manager",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "prisma generate && remix vite:build",
    "dev": "shopify app dev",
    "start": "node server.mjs",
    "docker-start": "remix-serve ./build/server/index.js",
    "setup": "prisma generate && prisma migrate deploy",
